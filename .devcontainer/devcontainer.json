{
    "name": "Underactuated Robotics Env",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    },
    "forwardPorts": [7000, 8888],
    "postCreateCommand": "pip install -r requirements.txt",
    "remoteUser": "root"
}